{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shop Definition Schema",
  "description": "Schema for validating shop definitions in the Godot farm game",
  "type": "object",
  "required": ["id", "name", "inventory"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z_0-9]*$"
    },
    "name": {
      "type": "string"
    },
    "name_key": {
      "type": "string"
    },
    "description_key": {
      "type": "string"
    },
    "owner_npc": {
      "type": "string"
    },
    "inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "item_type", "buy_price"],
        "properties": {
          "item_id": {
            "type": "string"
          },
          "crop_ref": {
            "type": "string"
          },
          "item_type": {
            "type": "string",
            "enum": ["seed", "tool", "consumable", "upgrade"]
          },
          "buy_price": {
            "type": "integer",
            "minimum": 0
          },
          "sell_price": {
            "type": "integer",
            "minimum": 0
          },
          "unlock_level": {
            "type": "integer",
            "minimum": 1
          },
          "stock": {
            "oneOf": [
              {"type": "integer", "minimum": 0},
              {"type": "string", "enum": ["unlimited"]}
            ]
          },
          "restock_time": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "shop_hours": {
      "type": "object",
      "properties": {
        "open": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23
        },
        "close": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23
        }
      }
    },
    "location": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
